# ── RabbitMQ ───────────────────────────────────────────────
RABBITMQ_PORT=5672
RABBITMQ_MANAGEMENT_PORT=15672
RABBITMQ_URL=amqp://guest:guest@rabbitmq:5672/

# ── Servicios ──────────────────────────────────────────────
API_GATEWAY_PORT=8000
MS_CATALOGOS_PORT=8001
MS_INVENTARIO_PORT=8002
MS_AUTH_PORT=8003
MS_COMPRAS_PORT=8004
MS_VENTAS_PORT=8005
MS_FINANZAS_PORT=8006
MS_REPORTES_PORT=8007
MS_COMPANY_PORT=8008
MS_CLIENTES_PORT=8009
MS_NOTIFICACIONES_PORT=8010
MS_CHATBOT_PORT=8011
FRONTEND_PORT=5173

# ── api-gateway ────────────────────────────────────────────
MS_CATALOGOS_URL=http://ms-catalogos:8001
MS_INVENTARIO_URL=http://ms-inventario:8002
MS_AUTH_URL=http://ms-auth:8003
MS_COMPRAS_URL=http://ms-compras:8004
MS_VENTAS_URL=http://ms-ventas:8005
MS_FINANZAS_URL=http://ms-finanzas:8006
MS_REPORTES_URL=http://ms-reportes:8007
MS_COMPANY_URL=http://ms-company:8008
MS_CLIENTES_URL=http://ms-clientes:8009
MS_NOTIFICACIONES_URL=http://ms-notificaciones:8010
MS_CHATBOT_URL=http://ms-chatbot:8011
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256

# ── ms-catalogos ───────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://catalogos_user:catalogos_secret@postgres-catalogos:5432/catalogos_db

# ── ms-inventario ──────────────────────────────────────────
SERVICE_NAME=ms-inventario
RUN_SEED=true

# ── ms-auth ────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# ── ms-compras ─────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://compras_user:compras_secret@postgres-compras:5432/compras_db
SERVICE_NAME=ms-compras
RUN_SEED=true
MS_INVENTARIO_URL=http://ms-inventario:8002
MS_FINANZAS_URL=http://ms-finanzas:8006

# ── ms-chatbot ─────────────────────────────────────────────
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=
WHATSAPP_VERIFY_TOKEN=
WHATSAPP_APP_SECRET=
WHATSAPP_API_VERSION=v20.0
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
