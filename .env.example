# ── PostgreSQL (ms-catalogos) ──────────────────────────────
POSTGRES_USER=catalogos_user
POSTGRES_PASSWORD=catalogos_secret
POSTGRES_DB=catalogos_db
POSTGRES_PORT=5432

# ── PostgreSQL (ms-inventario) ─────────────────────────────
POSTGRES_INVENTARIO_USER=inventario_user
POSTGRES_INVENTARIO_PASSWORD=inventario_secret
POSTGRES_INVENTARIO_DB=inventario_db
POSTGRES_INVENTARIO_PORT=5433

# ── PostgreSQL (ms-auth) ───────────────────────────────────
POSTGRES_AUTH_USER=auth_user
POSTGRES_AUTH_PASSWORD=auth_secret
POSTGRES_AUTH_DB=auth_db
POSTGRES_AUTH_PORT=5434

# ── PostgreSQL (ms-compras) ────────────────────────────────
POSTGRES_COMPRAS_USER=compras_user
POSTGRES_COMPRAS_PASSWORD=compras_secret
POSTGRES_COMPRAS_DB=compras_db
POSTGRES_COMPRAS_PORT=5435

# ── PostgreSQL (ms-ventas) ─────────────────────────────────
POSTGRES_VENTAS_USER=ventas_user
POSTGRES_VENTAS_PASSWORD=ventas_secret
POSTGRES_VENTAS_DB=ventas_db
POSTGRES_VENTAS_PORT=5436

# ── PostgreSQL (ms-finanzas) ───────────────────────────────
POSTGRES_FINANZAS_USER=finanzas_user
POSTGRES_FINANZAS_PASSWORD=finanzas_secret
POSTGRES_FINANZAS_DB=finanzas_db
POSTGRES_FINANZAS_PORT=5437

# ── PostgreSQL (ms-reportes) ───────────────────────────────
POSTGRES_REPORTES_USER=reportes_user
POSTGRES_REPORTES_PASSWORD=reportes_secret
POSTGRES_REPORTES_DB=reportes_db
POSTGRES_REPORTES_PORT=5438

# ── Servicios ──────────────────────────────────────────────
API_GATEWAY_PORT=8000
MS_CATALOGOS_PORT=8001
MS_INVENTARIO_PORT=8002
MS_AUTH_PORT=8003
MS_COMPRAS_PORT=8004
MS_VENTAS_PORT=8005
MS_FINANZAS_PORT=8006
MS_REPORTES_PORT=8007
FRONTEND_PORT=5173

# ── api-gateway ────────────────────────────────────────────
MS_CATALOGOS_URL=http://ms-catalogos:8001
MS_INVENTARIO_URL=http://ms-inventario:8002
MS_AUTH_URL=http://ms-auth:8003
MS_COMPRAS_URL=http://ms-compras:8004
MS_VENTAS_URL=http://ms-ventas:8005
MS_FINANZAS_URL=http://ms-finanzas:8006
MS_REPORTES_URL=http://ms-reportes:8007
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
JWT_SECRET=change-me-in-production
JWT_ALGORITHM=HS256

# ── ms-catalogos ───────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://catalogos_user:catalogos_secret@postgres-catalogos:5432/catalogos_db

# ── ms-inventario ──────────────────────────────────────────
SERVICE_NAME=ms-inventario
RUN_SEED=true

# ── ms-auth ────────────────────────────────────────────────
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7
